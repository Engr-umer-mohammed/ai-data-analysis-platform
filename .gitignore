# .gitignore
# Files and folders to NEVER upload to GitHub

# ── SECRET FILES ──────────────────────────────────────
.env
*.env
.env.local
.env.production
secrets.json

# ── PYTHON CACHE ──────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# ── VIRTUAL ENVIRONMENTS ──────────────────────────────
venv/
env/
ENV/
.venv/
.env/

# ── BUILD AND DISTRIBUTION ────────────────────────────
build/
dist/
*.egg-info/
*.egg
.eggs/

# ── IDE FILES ─────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ── GENERATED OUTPUT FILES ────────────────────────────
# These are created by the agent at runtime
# Do not commit them to GitHub
reports/
excel_reports/
charts/
temp/

# ── DATA FILES ────────────────────────────────────────
# Do not commit client data to GitHub
*.csv
*.xlsx
*.xls
*.json
# Exception — keep example data files
!sample_data/*.csv
!sample_data/*.xlsx

# ── HISTORY FILES ─────────────────────────────────────
analysis_history.json
fault_history.json

# ── JUPYTER NOTEBOOKS ─────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── LOGS ──────────────────────────────────────────────
*.log
logs/

# ── OS FILES ──────────────────────────────────────────
Thumbs.db
.DS_Store